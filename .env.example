# JustEvents — secrets configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Discord Bot Token from the Discord Developer Portal
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord Server (Guild) ID
# Right-click your server in Discord → "Copy Server ID"
DISCORD_GUILD_ID=your-guild-id-here

# Optional default mode override for all sources: direct, sesh, justevent
# JUSTEVENTS_DEFAULT_EVENT_CREATION_METHOD=direct

# Optional global command channel override for sesh/justevent modes
# JUSTEVENTS_COMMAND_CHANNEL_ID=123456789012345678
